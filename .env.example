# --- LLM（默认 DeepSeek）---
DEEPSEEK_API_KEY=your_deepseek_key
CHUNK_LLM_MODEL=deepseek-chat
CHUNK_LLM_PROVIDER=deepseek

# --- 向量库（默认内存 FAISS）---
# faiss | qdrant | milvus | chroma | pinecone
VECTOR_STORE_PROVIDER=faiss
VECTOR_STORE_COLLECTION_PREFIX=chunk_lab

# Qdrant（云端或本地）
# VECTOR_STORE_PROVIDER=qdrant
# QDRANT_BASE_URL=https://xxx.qdrant.io
# QDRANT_API_KEY=your_qdrant_key
# CHUNK_QDRANT_URL=
# CHUNK_QDRANT_API_KEY=

# Milvus
# VECTOR_STORE_PROVIDER=milvus
# CHUNK_MILVUS_URI=http://localhost:19530
# CHUNK_MILVUS_TOKEN=

# Chroma（留空 CHROMA_PERSIST_DIR 为纯内存）
# VECTOR_STORE_PROVIDER=chroma
# CHROMA_PERSIST_DIR=./.chroma_chunk_lab

# Pinecone
# VECTOR_STORE_PROVIDER=pinecone
# PINECONE_API_KEY=your_pinecone_key
# CHUNK_PINECONE_INDEX_NAME=chunk-lab
# CHUNK_PINECONE_NAMESPACE=

# --- Embeddings ---
# huggingface | openai | deepseek | mistral | qwen | dashscope
CHUNK_EMBEDDING_PROVIDER=huggingface
CHUNK_EMBEDDING_MODEL=BAAI/bge-small-zh-v1.5

# Mistral Embedding
# CHUNK_EMBEDDING_PROVIDER=mistral
# CHUNK_EMBEDDING_MODEL=mistral-embed
# MISTRAL_API_KEY=your_mistral_key

# 通义千问 / Qwen（DashScope）
# CHUNK_EMBEDDING_PROVIDER=qwen
# CHUNK_EMBEDDING_MODEL=text-embedding-v3
# DASHSCOPE_API_KEY=your_dashscope_key

# DeepSeek / OpenAI 兼容 Embedding
# CHUNK_EMBEDDING_PROVIDER=deepseek
# CHUNK_EMBEDDING_MODEL=deepseek-embedding
# CHUNK_EMBEDDING_API_BASE=https://api.deepseek.com

# --- 分块参数 ---
CHUNK_BASELINE_SIZE=512
CHUNK_BASELINE_OVERLAP=128
CHUNK_SEMANTIC_MIN_SIZE=150
CHUNK_CHILD_SIZE=200
CHUNK_PARENT_SIZE=800
CHUNK_CONTEXTUAL_MAX_CHUNKS=20
CHUNK_EVAL_TOP_K=5
PAPERS_CACHE_DIR=data/papers

# --- LLM-as-Judge 评估（默认关闭）---
# CHUNK_EVAL_JUDGE_ENABLED=true
# CHUNK_EVAL_JUDGE_MODE=both
# judge: 仅 LLM 评判 | both: 子串 recall@k + LLM 评判
# CHUNK_EVAL_JUDGE_TEMPERATURE=0
# CHUNK_EVAL_JUDGE_MAX_TOKENS=1024
# 评判 LLM 未设置时复用 CHUNK_LLM_*（DeepSeek）
# CHUNK_EVAL_JUDGE_LLM_MODEL=deepseek-chat
# CHUNK_EVAL_JUDGE_LLM_PROVIDER=deepseek

# --- 可观测性（默认均关闭；即使 .env 有 LANGSMITH_TRACING 也会被显式关闭）---
# CHUNK_LANGSMITH_ENABLED=true
# CHUNK_LANGSMITH_PROJECT=rag-chunk-strategy
# LANGSMITH_API_KEY=your_langsmith_key

# CHUNK_LANGFUSE_ENABLED=true
# CHUNK_LANGFUSE_PROJECT=rag-chunk-strategy
# LANGFUSE_PUBLIC_KEY=pk-lf-...
# LANGFUSE_SECRET_KEY=sk-lf-...
# LANGFUSE_BASE_URL=https://cloud.langfuse.com
